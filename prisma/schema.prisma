// FAIITA — Prisma Schema
// Production datasource: Neon Postgres.
// url = pooled connection (has "-pooler" in the hostname) — used at runtime.
// directUrl = direct, non-pooled connection — used for migrations only.
// Both come from environment variables — see .env / Vercel env vars.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// One row per Indian state/UT covered by FAIITA — powers the interactive map,
/// /about/state-associations, and the /about/state-associations/[slug] pages.
model StateAssociation {
  id               String   @id @default(cuid())
  slug             String   @unique
  stateName        String
  stateCode        String // e.g. "MH", "DL" — matches map region ids
  region           String // North | South | East | West | Central | North-East
  associationName  String
  foundedYear      Int?
  memberCount      Int      @default(0)
  presidentName    String?
  secretaryName    String?
  contactEmail     String?
  contactPhone     String?
  address          String?
  description      String?
  logoUrl          String?
  mapX             Float // relative x position (0-100) on the illustrated map
  mapY             Float // relative y position (0-100) on the illustrated map
  isCovered        Boolean  @default(true)
  memberAssociations MemberAssociation[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([region])
}

/// Individual member associations that belong to a state chapter.
model MemberAssociation {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  city        String?
  type        String // Retail | Distribution | Services | Solutions | Manufacturing
  memberCount Int      @default(0)
  description String?
  logoUrl     String?
  website     String?
  stateId     String
  state       StateAssociation @relation(fields: [stateId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([stateId])
}

/// National leadership — Governing Body / office bearers.
model Leader {
  id              String   @id @default(cuid())
  name            String
  role            String // President, Sr. Vice President, Secretary General, etc.
  order           Int      @default(0)
  bio             String?
  imageUrl        String?
  associationName String?
  stateName       String?
  email           String?
  phone           String?
  linkedIn        String?
  category        String   @default("national") // national | state
  term            String   @default("2024–2026") // e.g. "2024–2026", FAIITA GB terms run 2 years
  isCurrent       Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([category, order])
}

model News {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  excerpt       String
  content       String
  category      String // Events | Policy | Initiative | Press Release
  coverImage    String?
  featured      Boolean  @default(false)
  publishedAt   DateTime @default(now())

  @@index([publishedAt])
}

model Event {
  id                 String   @id @default(cuid())
  slug               String   @unique
  title              String
  description        String
  category           String // AGM | Summit | Workshop | Conference
  startDate          DateTime
  endDate            DateTime?
  city               String
  state              String
  venue              String?
  coverImage         String?
  registrationLink   String?
  isUpcoming         Boolean  @default(true)
  createdAt          DateTime @default(now())

  @@index([startDate])
}

model Blog {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  author      String
  authorRole  String?
  coverImage  String?
  tags        String // comma separated
  publishedAt DateTime @default(now())

  @@index([publishedAt])
}

model GalleryItem {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  category  String // Events | Summits | Leadership | Regional Meets
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([category])
}

model Newsletter {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileUrl     String?
  issueNumber Int
  issueDate   DateTime

  @@index([issueDate])
}

model Policy {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String // Annual | Research | Policy | White Paper
  fileUrl     String?
  fileSize    String? // e.g. "4.2 MB"
  publishedAt DateTime @default(now())

  @@index([category])
}

model Testimonial {
  id          String  @id @default(cuid())
  name        String
  role        String
  association String
  quote       String
  imageUrl    String?
  order       Int     @default(0)
}

model Stat {
  id       String @id @default(cuid())
  label    String
  value    String // stored as string to allow "29", "100+", "5L+"
  suffix   String?
  icon     String? // lucide icon name
  order    Int    @default(0)
}

model ContactSubmission {
  id           String   @id @default(cuid())
  name         String
  email        String
  phone        String?
  organization String?
  subject      String?
  message      String
  createdAt    DateTime @default(now())
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())
}
