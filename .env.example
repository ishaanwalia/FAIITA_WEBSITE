# --- Database -----------------------------------------------------
# prisma/schema.prisma is hardcoded to provider = "postgresql" — a Neon or
# Supabase connection string is required even for local dev (see README.md
# "Database setup"). A free Neon project takes under a minute to create.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# --- Contact form email (optional but recommended) -----------------
# Free tier at https://resend.com — used by app/api/contact/route.ts.
# Until faiita.co.in is verified in Resend, only onboarding@resend.dev works
# as CONTACT_FROM_EMAIL, and it only delivers to the Resend account owner.
RESEND_API_KEY=""
CONTACT_TO_EMAIL="secretary@faiita.co.in"
CONTACT_FROM_EMAIL="FAIITA Website <onboarding@resend.dev>"

# --- Site -----------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://www.faiita.co.in"
